/* ===================================
   AUDIO PLAYER
   =================================== */
.audio-player-container {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(26, 26, 26, 0.95);
    padding: 12px 20px;
    border-radius: 50px;
    border: 2px solid rgba(86, 116, 234, 0.3);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(86, 116, 234, 0.2);
    animation: slideInRight 0.5s ease-out;
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(100px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.audio-toggle {
    background: linear-gradient(135deg, var(--pink) 0%, var(--pink-light) 100%);
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(86, 116, 234, 0.3);
    font-size: 1.5rem;
}

.audio-toggle:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(86, 116, 234, 0.4);
}

.audio-toggle:active {
    transform: scale(0.95);
}

.audio-toggle.playing {
    animation: pulse-music 1.5s infinite;
}

@keyframes pulse-music {
    0%, 100% {
        box-shadow: 0 4px 15px rgba(86, 116, 234, 0.3);
    }
    50% {
        box-shadow: 0 4px 25px rgba(86, 116, 234, 0.6);
    }
}

.music-icon {
    display: inline-block;
    transition: transform 0.3s ease;
}

.audio-toggle.playing .music-icon {
    animation: bounce-music 0.6s infinite;
}

.audio-player-container {
  display: none; /* Menyembunyikan tombol musik di awal */
  position: fixed;
  /* ... kode CSS Anda yang lain ... */
}

@keyframes bounce-music {
    0%, 100% {
        transform: translateY(0);
    }
    50% {
        transform: translateY(-5px);
    }
}

.audio-info {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.song-title {
    color: var(--text-light);
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
}

.song-artist {
    color: var(--text-muted);
    font-size: 0.8rem;
    white-space: nowrap;
}

/* Audio element styling (untuk browser yang support) */
audio {
    display: none;
}

/* Responsive audio player */
@media (max-width: 768px) {
    .audio-player-container {
        bottom: 20px;
        right: 20px;
        padding: 10px 15px;
        gap: 10px;
    }

    .audio-toggle {
        width: 45px;
        height: 45px;
        font-size: 1.2rem;
    }

    .song-title {
        font-size: 0.85rem;
    }

    .song-artist {
        font-size: 0.7rem;
    }
}

@media (max-width: 576px) {
    .audio-player-container {
        bottom: 15px;
        right: 15px;
        padding: 8px 12px;
        gap: 8px;
        border-radius: 40px;
    }

    .audio-toggle {
        width: 40px;
        height: 40px;
        font-size: 1rem;
    }

    .audio-info {
        display: none;
    }

    .audio-player-container:hover .audio-info {
        display: flex;
        position: absolute;
        bottom: 60px;
        right: 0;
        background: rgba(26, 26, 26, 0.95);
        padding: 10px 15px;
        border-radius: 10px;
        border: 2px solid rgba(86, 116, 234, 0.3);
        white-space: nowrap;
    }
}

:root {
    --pink: #5674ea;
    --pink-light: #7c8ff0;
    --bg: #0a0a0a;
    --bg-secondary: #1a1a1a;
    --bg-tertiary: #2a2a2a;
    --shadow: 1px 1px 8px rgba(0,0,0,0.8);
    --shadow-strong: 2px 2px 6px rgba(0,0,0,0.9);
    --shadow-glow: 0 0 8px rgba(0,0,0,0.8);
    --shadow-outline: 
        -1px -1px 0 #000,
        1px -1px 0 #000,
        -1px  1px 0 #000,
        1px  1px 0 #000,
        2px  2px 6px rgba(0,0,0,0.8);
    --text-light: #ffffff;
    --text-muted: #b0b0b0;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-size: 1.2rem;
    font-family: "Work Sans", sans-serif;
    background-color: var(--bg);
    color: var(--text-light);
    line-height: 1.6;
}

html {
    scroll-behavior: smooth;
}

/* ===================================
   HERO SECTION
   =================================== */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url(gambar/6211c0000290e.jpeg);
    background-position: center;
    background-size: cover;
    background-attachment: fixed;
    z-index: -1;
    filter: brightness(0.4) contrast(1.1);
}

.hero::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(86, 116, 234, 0.1) 0%, rgba(10, 10, 10, 0.5) 100%);
    z-index: -1;
}

.hero main {
    text-align: center;
    animation: slideInUp 0.8s ease-out;
    max-width: 600px;
    padding: 2rem;
}

.hero h1,
.hero h4,
.hero p {
    text-shadow: var(--shadow-outline);
    animation: fadeInDown 0.6s ease-out;
}

.hero h1 {
    font-family: "Sacramento", cursive;
    font-size: 4rem;
    color: var(--text-light);
    margin-bottom: 1rem;
    font-weight: 400;
}

.hero h4 {
    font-size: 1.6rem;
    color: var(--pink-light);
    margin-bottom: 1rem;
    font-weight: 300;
    letter-spacing: 1px;
}

.hero p {
    font-size: 1.2rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    font-weight: 300;
}

.hero a {
    color: var(--pink);
    background-color: var(--text-light);
    text-decoration: none;
    padding: 12px 40px;
    border-radius: 50px;
    display: inline-block;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
    border: 2px solid var(--text-light);
}

.hero a:hover {
    background-color: var(--pink);
    color: var(--text-light);
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(86, 116, 234, 0.4);
}

.hero a:active {
    transform: translateY(-1px);
}

/* ===================================
   COUNTDOWN
   =================================== */
.simply-countdown {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 2rem 0;
    animation: fadeInUp 0.8s ease-out 0.2s both;
}

.simply-countdown > .simply-section {
    padding: 30px 20px;
    margin: 3px;
    background-color: rgba(86, 116, 234, 0.15);
    border: 2px solid var(--pink);
    border-radius: 10px;
    min-width: 80px;
    text-align: center;
    box-shadow: var(--shadow-glow);
    transition: all 0.3s ease;
}

.simply-countdown > .simply-section:hover {
    background-color: rgba(86, 116, 234, 0.25);
    transform: scale(1.05);
}

.simply-countdown .simply-amount {
    font-size: 2rem;
    font-weight: bold;
    color: var(--pink);
    display: block;
}

.simply-countdown .simply-word {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-top: 0.5rem;
    letter-spacing: 1px;
}

