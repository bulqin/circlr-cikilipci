   <script>

  // 1. Inisialisasi Countdown
  simplyCountdown('.simply-countdown', {
    year: 2026,
    month: 6,
    day: 28,
    hours: 8,
    minutes: 0,
    seconds: 0,
    words: {
        days: { root: 'hari', lambda: (root, n) => n > 1 ? root : root },
        hours: { root: 'jam', lambda: (root, n) => n > 1 ? root : root },
        minutes: { root: 'menit', lambda: (root, n) => n > 1 ? root : root },
        seconds: { root: 'detik', lambda: (root, n) => n > 1 ? root : root }
    },
  });

  // 2. Deklarasi Elemen DOM
  const bgMusic = document.getElementById('bgMusic');
  const audioToggle = document.getElementById('audioToggle');
  const lihatUndangan = document.getElementById('lihatUndangan');
  const audioContainer = document.querySelector('.audio-player-container');
  const heroSection = document.getElementById('hero');
  const navBrand = document.getElementById('navBrand');

  let isPlaying = false;

  // 3. Fungsi Kontrol Musik
  function playMusic() {
    if (bgMusic) {
      bgMusic.play().catch(error => console.log("Autoplay diblokir browser:", error));
      audioToggle.classList.add('playing');
      isPlaying = true;
    }
  }

  function pauseMusic() {
    if (bgMusic) {
      bgMusic.pause();
      audioToggle.classList.remove('playing');
      isPlaying = false;
    }
  }

  if (audioToggle) {
    audioToggle.addEventListener('click', () => {
      if (isPlaying) {
        pauseMusic();
      } else {
        playMusic();
      }
    });
  }

  // 4. Logika Pindah Halaman & Buka Undangan
  if (lihatUndangan) {
    lihatUndangan.addEventListener('click', function(e) {
      e.preventDefault(); // Mencegah lompatan instan bawaan HTML

      // Putar musik saat diklik
      playMusic();

      // Munculkan tombol musik di pojok
      if (audioContainer) {
        audioContainer.style.display = 'flex'; 
      }

      // Cari elemen target (#undangan)
      const undanganSection = document.getElementById('undangan');
      
      if (undanganSection) {
        // Geser ke bawah secara halus ke bagian undangan
        undanganSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Opsional: Jika kamu ingin menyembunyikan hero section agar tidak bisa di-scroll ke atas lagi,
        // lebih baik gunakan class animasi CSS atau biarkan saja secara natural.
        // Menghapus setTimeout dan window.scrollTo(0,0) akan menyelesaikan masalah lompatan.
      }
    });
  }
   </script>
