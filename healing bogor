.undangan .card-text {
    color: var(--text-muted);
    line-height: 1.8;
}

.undangan strong {
    color: var(--pink-light);
}

.undangan p {
    color: var(--text-light);
    margin: 0.5rem 0;
}

/* ===================================
   INFO SECTION
   =================================== */
.info {
    padding: 80px 0;
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg) 100%);
    position: relative;
}

.info h2 {
    color: var(--pink);
    font-size: 2.5rem;
    margin-bottom: 3rem;
    position: relative;
    display: inline-block;
    width: 100%;
    text-align: center;
}

.info h2::after {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 3px;
    background: linear-gradient(to right, var(--pink), transparent);
}

.info .card {
    background: var(--bg-secondary);
    border: 2px solid rgba(86, 116, 234, 0.3);
    border-radius: 12px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
}

.info .card:hover {
    border-color: var(--pink);
    transform: translateY(-8px);
    box-shadow: 0 0 25px rgba(86, 116, 234, 0.3);
    background: linear-gradient(135deg, rgba(86, 116, 234, 0.1) 0%, var(--bg-secondary) 100%);
}

.info .card-title {
    color: var(--pink);
    font-size: 1.8rem;
    margin-bottom: 1rem;
}

.info .card-text {
    color: var(--text-muted);
    font-weight: 500;
}

/* ===================================
   LOKASI SECTION
   =================================== */
.lokasi {
    padding: 80px 0;
    background: var(--bg);
}

.lokasi h2 {
    color: var(--pink);
    font-size: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
}

.lokasi iframe {
    border-radius: 15px;
    border: 2px solid rgba(86, 116, 234, 0.3);
    box-shadow: var(--shadow-glow);
    transition: all 0.3s ease;
}

.lokasi iframe:hover {
    border-color: var(--pink);
    box-shadow: 0 0 30px rgba(86, 116, 234, 0.3);
}

.lokasi .text-muted {
    color: var(--text-muted) !important;
    font-style: italic;
    font-size: 0.95rem;
}

/* ===================================
   GALLERY SECTION
   =================================== */
.gallery {
    padding: 80px 0;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-secondary) 100%);
    position: relative;
}

.gallery h2 {
    color: var(--pink);
    font-size: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
}

.gallery img {
    border-radius: 12px;
    border: 2px solid rgba(86, 116, 234, 0.3);
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
}

.gallery img:hover {
    border-color: var(--pink);
    transform: scale(1.05) rotate(-2deg);
    box-shadow: 0 0 30px rgba(86, 116, 234, 0.3);
}

.gallery .col-md-4 {
    animation: fadeInUp 0.6s ease-out;
}

.gallery .col-md-4:nth-child(1) {
    animation-delay: 0s;
}

.gallery .col-md-4:nth-child(2) {
    animation-delay: 0.1s;
}

.gallery .col-md-4:nth-child(3) {
    animation-delay: 0.2s;
}

/* ===================================
   RSVP SECTION
   =================================== */
.rsvp {
    padding: 80px 0;
    background: var(--bg-secondary);
    position: relative;
}

.rsvp h2 {
    color: var(--pink);
    font-size: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
}

.form-label {
    color: var(--pink-light);
    font-weight: 600;
    margin-bottom: 0.7rem;
}

.form-control {
    background: var(--bg);
    border: 2px solid rgba(86, 116, 234, 0.3);
    color: var(--text-light);
    padding: 12px 15px;
    border-radius: 8px;
    transition: all 0.3s ease;
    font-size: 1rem;
}

.form-control::placeholder {
    color: var(--text-muted);
}

.form-control:focus {
    background: var(--bg);
    border-color: var(--pink);
    box-shadow: 0 0 15px rgba(86, 116, 234, 0.3);
    color: var(--text-light);
}

.form-check-input {
    background: var(--bg);
    border: 2px solid rgba(86, 116, 234, 0.3);
    width: 1.25em;
    height: 1.25em;
    transition: all 0.3s ease;
    cursor: pointer;
}

.form-check-input:checked {
    background-color: var(--pink);
    border-color: var(--pink);
    box-shadow: 0 0 10px rgba(86, 116, 234, 0.5);
}

.form-check-input:focus {
    border-color: var(--pink);
    box-shadow: 0 0 10px rgba(86, 116, 234, 0.3);
}

.form-check-label {
    color: var(--text-light);
    font-weight: 500;
    cursor: pointer;
    margin-left: 0.5rem;
    transition: all 0.3s ease;
}

.form-check-label:hover {
    color: var(--pink);
}

textarea.form-control {
    resize: vertical;
    min-height: 120px;
}

.btn-primary {
    background: linear-gradient(135deg, var(--pink) 0%, var(--pink-light) 100%);
    border: none;
    color: white;
    padding: 12px 30px;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.3s ease;
    font-size: 1rem;
    box-shadow: 0 4px 15px rgba(86, 116, 234, 0.3);
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(86, 116, 234, 0.4);
    color: white;
}

.btn-primary:active {
    transform: translateY(-1px);
}

.btn-primary:focus {
    color: white;
    box-shadow: 0 0 20px rgba(86, 116, 234, 0.5);
}

/* ===================================
   FOOTER
   =================================== */
footer {
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg) 100%);
    border-top: 2px solid rgba(86, 116, 234, 0.3);
    padding: 2rem 0;
    color: var(--text-muted);
    text-align: center;
}

footer p {
    margin: 0;
    transition: all 0.3s ease;
}

footer:hover p {
    color: var(--pink);
}

/* ===================================
   ANIMATIONS
   =================================== */
@keyframes slideInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ===================================
   SCROLLBAR CUSTOM
   =================================== */
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: var(--bg);
}

::-webkit-scrollbar-thumb {
    background: var(--pink);
    border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--pink-light);
}

/* ===================================
   MEDIA QUERIES
   =================================== */
/* Laptop */
@media (max-width: 992px) {
    html {
        font-size: 75%;
    }

    .hero h1 {
        font-size: 3rem;
    }

    .hero h4 {
        font-size: 1.4rem;
    }
}

/* Tablet */
@media (max-width: 768px) {
    html {
        font-size: 65%;
    }

    .hero {
        min-height: 80vh;
    }

    .hero h1 {
        font-size: 2.5rem;
    }

    .hero h4 {
        font-size: 1.2rem;
    }

    .undangan,
    .info,
    .lokasi,
    .gallery,
    .rsvp {
        padding: 50px 0;
    }

    .info .card,
    .gallery .col-md-4 {
        margin-bottom: 1.5rem;
    }

    .simply-countdown > .simply-section {
        padding: 20px 15px;
        min-width: 70px;
    }

    .simply-countdown .simply-amount {
        font-size: 1.5rem;
    }

    .simply-countdown .simply-word {
        font-size: 0.7rem;
    }
}

/* Mobile Phone */
@media (max-width: 576px) {
    html {
        font-size: 60%;
    }

    .hero {
        min-height: 70vh;
        padding: 1.5rem;
    }

    .hero main {
        max-width: 100%;
    }

    .hero h1 {
        font-size: 2rem;
    }

    .hero h4 {
        font-size: 1rem;
    }

    .hero p {
        font-size: 0.95rem;
    }

    .hero a {
        padding: 10px 30px;
        font-size: 0.9rem;
    }

    .undangan,
    .info,
    .lokasi,
    .gallery,
    .rsvp {
        padding: 30px 0;
    }

    .undangan .card {
        padding: 1.5rem !important;
    }

    .undangan .card-title {
        font-size: 1.8rem;
    }

    .info h2,
    .lokasi h2,
    .gallery h2,
    .rsvp h2 {
        font-size: 1.8rem;
    }

    .info .card-title {
        font-size: 1.3rem;
    }

    .form-label {
        font-size: 0.95rem;
    }

    .form-control {
        font-size: 0.9rem;
    }

    .simply-countdown {
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .simply-countdown > .simply-section {
        flex: 1;
        min-width: 60px;
        padding: 15px 10px;
    }

    .simply-countdown .simply-amount {
        font-size: 1.2rem;
    }

    .simply-countdown .simply-word {
        font-size: 0.65rem;
    }

    .navbar-brand {
        font-size: 1.4rem;
    }

    .nav-link {
        font-size: 0.95rem;
    }
}

/* ===================================
   UTILITY CLASSES
   =================================== */
.text-pink {
    color: var(--pink) !important;
}

.bg-dark-secondary {
    background-color: var(--bg-secondary) !important;
}

.border-pink {
    border-color: var(--pink) !important;
}

.shadow-pink {
    box-shadow: 0 0 20px rgba(86, 116, 234, 0.3) !important;
}

/* Smooth transitions untuk semua elemen */
body * {
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}
